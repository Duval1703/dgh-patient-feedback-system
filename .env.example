# Backend Environment Variables
# Database Configuration (from Supabase)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST].supabase.co:5432/postgres

# Twilio Configuration (for SMS reminders)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# JWT Configuration
SECRET_KEY=your_secret_key_here_generate_a_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend Environment Variables (for Netlify)
# Create a file: Frontend/.env.production
VITE_BACKEND_URL=https://your-render-backend-url.onrender.com
